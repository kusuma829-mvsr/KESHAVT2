{% extends "src/templates/base.njk" %}
{% block content %}
<div class="contact-section">
    <div class="container">
        <div class="row align-items-center g-4">
            <!-- LEFT SIDE -->
            <div class="col-md-6">
                <h2>Contact Us</h2>
                <p>Reach out to us anytime</p>
                <p><i class="bi bi-envelope"></i> support@keshavsoft.com</p>
                <p><i class="bi bi-phone"></i> +91 9876543210</p>
            </div>
            <div class="col-md-6">
                <div class="form-box shadow-sm">
                    <form>
                        <div class="mb-3">
                            <input type="text" class="form-control" placeholder="Your Name" required>
                        </div>
                        <div class="mb-3">
                            <input type="email" class="form-control" placeholder="Your Email" required>
                        </div>
                        <div class="mb-3">
                            <textarea class="form-control" rows="4" placeholder="Your Message"></textarea>
                        </div>
                        <button class="btn btn-primary w-100">
                            Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}